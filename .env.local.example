# PSA Academy Environment Configuration
# Cloudflare-powered development and deployment

# API Configuration - Cloudflare Tunnel
VITE_API_BASE_URL=https://printing-interviews-foster-seemed.trycloudflare.com/charming_api

# Production (Cloudflare Workers)
# VITE_API_BASE_URL=https://psa-academy.workers.dev/api

# App Configuration
VITE_APP_NAME=PSA Academy
VITE_APP_VERSION=1.0.0
VITE_ENABLE_DEBUG=false
VITE_CDN_MODE=cloudflare

# Instructions:
# 1. Keep Cloudflare tunnel running for development
# 2. Deploy to Cloudflare Workers/Pages for production
# 3. No ngrok needed - Cloudflare handles everything
