# PSA Academy Environment Configuration
# Using ngrok to expose local XAMPP/PHP backend to deployed frontend

# API Configuration

# Development (using Cloudflare tunnel)
VITE_API_BASE_URL=https://printing-interviews-foster-seemed.trycloudflare.com/charming_api

# Production (custom domain)
# VITE_API_BASE_URL=https://psa-academy.com/api

# Local development (XAMPP)
# VITE_API_BASE_URL=http://localhost/charming_api

# App Configuration
VITE_APP_NAME=PSA Academy
VITE_APP_VERSION=1.0.0
VITE_ENABLE_DEBUG=false

# Instructions:
# 1. Start ngrok: ngrok http 80
# 2. Copy the https URL from ngrok output
# 3. Replace YOUR_NGROK_URL above with your ngrok hash
# 4. Update Netlify environment variables with the ngrok URL
# 5. Redeploy Netlify site to apply changes
